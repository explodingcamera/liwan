---
import { CreateProject } from "../../components/settings/dialogs";
import { ProjectsTable } from "../../components/settings/tables";
import Settings from "../../layouts/Settings.astro";
---

<Settings title="Projects">
  <nav>
    <h1>Projects</h1>
    <CreateProject client:only="react" />
  </nav>
  <p class="description">Projects group one or more entities for dashboard reporting and access control.</p>
  <ProjectsTable client:load />
</Settings>

<style>
  .description {
    max-width: 46rem;
    margin-bottom: 1rem;
    color: var(--pico-muted-color);
  }
</style>

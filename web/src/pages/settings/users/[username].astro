---
import { UserSettingsPage } from "@/components/settings/users";
import Settings from "@/layouts/settings.astro";
import type { GetStaticPaths } from "astro";

export const getStaticPaths = (() => {
	return [{ params: { username: "user" } }];
}) satisfies GetStaticPaths;

const { username } = Astro.params;
---

<Settings title="User Settings">
  <UserSettingsPage username={username ?? ""} client:load />
</Settings>

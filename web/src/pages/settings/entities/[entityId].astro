---
import type { GetStaticPaths } from "astro";
import { EntitySettingsPage } from "@/components/settings/entities";
import Settings from "@/layouts/settings.astro";

export const getStaticPaths = (() => {
	return [{ params: { entityId: "entity" } }];
}) satisfies GetStaticPaths;

const { entityId } = Astro.params;
---

<Settings title="Entity Settings">
  <EntitySettingsPage entityId={entityId ?? ""} client:load />
</Settings>
